<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Checkout - <%= product.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
</head>
<body class="bg-gray-100 text-gray-800">

  <div class="max-w-7xl mx-auto p-6">
    <h1 class="text-3xl font-bold text-center mb-8">Checkout</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Shipping Form -->
      <div class="bg-white p-6 rounded-lg shadow-md">
        <h2 class="text-xl font-semibold mb-4">Shipping Information</h2>
        <form action="/complete-order" method="POST" id="checkout-form" class="space-y-4">
          <input type="hidden" name="orderId" value="<%= order._id %>"/>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block font-medium">First Name</label>
              <input type="text" name="firstName" required class="w-full border border-gray-300 rounded px-3 py-2">
            </div>
            <div>
              <label class="block font-medium">Last Name</label>
              <input type="text" name="lastName" required class="w-full border border-gray-300 rounded px-3 py-2">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block font-medium">Phone</label>
              <input type="text" name="phone" required class="w-full border border-gray-300 rounded px-3 py-2">
            </div>
            <div>
              <label class="block font-medium">Email</label>
              <input type="email" name="email" required class="w-full border border-gray-300 rounded px-3 py-2">
            </div>
          </div>

          <label class="block font-medium">Address</label>
          <input type="text" name="address" required class="w-full border border-gray-300 rounded px-3 py-2">

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block font-medium">City</label>
              <input type="text" name="city" required class="w-full border border-gray-300 rounded px-3 py-2">
            </div>
            <div>
              <label class="block font-medium">State</label>
              <select name="state" id="state" required class="w-full border border-gray-300 rounded px-3 py-2">
                <option value="">Select State</option>
              </select>
            </div>
            <div>
              <label class="block font-medium">ZIP</label>
              <input type="text" name="zip" required class="w-full border border-gray-300 rounded px-3 py-2">
            </div>
          </div>

          <!-- Payment -->
          <div class="mt-6">
            <h2 class="text-xl font-semibold mb-2">Payment Method</h2>
            <div class="space-y-4">
              <label class="block">
                <input type="radio" name="paymentMethod" value="credit" class="mr-2" required>
                Credit Card
              </label>
              <div class="payment-details hidden" id="credit-card-fields">
                <input type="text" id="cc-number" name="cc-number" placeholder="Card Number" class="w-full border rounded px-3 py-2 mb-2"/>
                <input type="text" id="cc-expiry" name="cc-expiry" placeholder="MM/YY" class="w-full border rounded px-3 py-2 mb-2"/>
                <input type="text" id="cc-cvv" name="cc-cvv" placeholder="CVV" class="w-full border rounded px-3 py-2"/>
              </div>

              <label class="block">
                <input type="radio" name="paymentMethod" value="debit" class="mr-2">
                Debit Card
              </label>
              <div class="payment-details hidden" id="debit-card-fields">
                <input type="text" id="dc-number" name="dc-number" placeholder="Card Number" class="w-full border rounded px-3 py-2 mb-2"/>
                <input type="text" id="dc-expiry" name="dc-expiry" placeholder="MM/YY" class="w-full border rounded px-3 py-2 mb-2"/>
                <input type="text" id="dc-cvv" name="dc-cvv" placeholder="CVV" class="w-full border rounded px-3 py-2"/>
              </div>

              <label class="block">
                <input type="radio" name="paymentMethod" value="upi" class="mr-2">
                UPI
              </label>
              <div class="payment-details hidden" id="upi-fields">
                <input type="text" id="upi-id" name="upi-id" placeholder="example@upi" class="w-full border rounded px-3 py-2"/>
              </div>

              <label class="block">
                <input type="radio" name="paymentMethod" value="cod" class="mr-2">
                Cash on Delivery (Extra ₹50)
              </label>
            </div>
          </div>

          <div class="mt-6 text-xl font-semibold">
            Total Amount: ₹<span id="total-amount"><%= product.price %></span>
          </div>

          <button type="submit" class="mt-4 w-full bg-green-600 text-white py-3 rounded hover:bg-green-700 transition">
            Place Order
          </button>
        </form>
      </div>

      <!-- Order Summary -->
      <div class="bg-white p-6 rounded-lg shadow-md">
        <h2 class="text-xl font-semibold mb-4">Order Summary</h2>
        <div class="flex space-x-4">
          <img src="<%= product.image %>" alt="<%= product.name %>" class="w-24 h-24 object-cover rounded" />
          <div>
            <h3 class="font-bold text-lg"><%= product.name %></h3>
            <p class="text-gray-700">₹<%= product.price %></p>
            <div class="mt-2 flex items-center space-x-2">
              <button id="decrease-quantity" class="px-2 py-1 bg-gray-300 rounded">-</button>
              <span id="quantity" class="font-semibold">1</span>
              <button id="increase-quantity" class="px-2 py-1 bg-gray-300 rounded">+</button>
            </div>
            <p class="mt-2">Subtotal: ₹<span id="subtotal"><%= product.price %></span></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // State Dropdown
    const states = ["Andhra Pradesh", "Arunachal Pradesh", "Assam", "Bihar", "Chhattisgarh", "Goa", "Gujarat", "Haryana",
      "Himachal Pradesh", "Jharkhand", "Karnataka", "Kerala", "Madhya Pradesh", "Maharashtra", "Manipur", "Meghalaya",
      "Mizoram", "Nagaland", "Odisha", "Punjab", "Rajasthan", "Sikkim", "Tamil Nadu", "Telangana", "Tripura",
      "Uttar Pradesh", "Uttarakhand", "West Bengal"];
    const stateSelect = document.getElementById("state");
    states.forEach(state => {
      const option = document.createElement("option");
      option.value = state;
      option.textContent = state;
      stateSelect.appendChild(option);
    });

    // Show/Hide Payment Fields
    document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
      radio.addEventListener('change', () => {
        document.querySelectorAll('.payment-details').forEach(el => el.classList.add('hidden'));
        if (radio.value === 'credit') document.getElementById('credit-card-fields').classList.remove('hidden');
        if (radio.value === 'debit') document.getElementById('debit-card-fields').classList.remove('hidden');
        if (radio.value === 'upi') document.getElementById('upi-fields').classList.remove('hidden');
        updateTotal();
      });
    });

    // Quantity Handling
    const quantityEl = document.getElementById("quantity");
    const subtotalEl = document.getElementById("subtotal");
    const totalAmountEl = document.getElementById("total-amount");
    const basePrice = parseFloat("<%= product.price %>");

    document.getElementById("increase-quantity").addEventListener("click", () => {
      quantityEl.textContent = +quantityEl.textContent + 1;
      updateTotal();
    });

    document.getElementById("decrease-quantity").addEventListener("click", () => {
      if (+quantityEl.textContent > 1) {
        quantityEl.textContent = +quantityEl.textContent - 1;
        updateTotal();
      }
    });

    function updateTotal() {
      const qty = +quantityEl.textContent;
      const method = document.querySelector('input[name="paymentMethod"]:checked')?.value;
      const extra = method === 'cod' ? 50 : 0;
      const subtotal = basePrice * qty;
      subtotalEl.textContent = subtotal.toFixed(2);
      totalAmountEl.textContent = (subtotal + extra).toFixed(2);
    }

    // Form Validation
    document.getElementById("checkout-form").addEventListener("submit", function (e) {
      const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked')?.value;

      if (!paymentMethod) {
        alert("Please select a payment method.");
        e.preventDefault();
        return;
      }

      if (paymentMethod === "credit" || paymentMethod === "debit") {
        const prefix = paymentMethod === "credit" ? "cc" : "dc";
        const number = document.getElementById(`${prefix}-number`).value;
        const expiry = document.getElementById(`${prefix}-expiry`).value;
        const cvv = document.getElementById(`${prefix}-cvv`).value;

        if (!number || !expiry || !cvv) {
          alert("Please fill in all card details.");
          e.preventDefault();
          return;
        }
      }

      if (paymentMethod === "upi" && !document.getElementById("upi-id").value) {
        alert("Please enter your UPI ID.");
        e.preventDefault();
        return;
      }
    });
  </script>
</body>
</html>
