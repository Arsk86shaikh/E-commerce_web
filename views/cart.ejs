<%- include('partials/header') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<div class="max-w-4xl mx-auto p-6 bg-white shadow-lg rounded-lg mt-10">
    <h2 class="text-3xl font-bold mb-6 text-center text-gray-800">Your Cart</h2>

    <% if (cart.length === 0) { %>
        <p class="text-center text-gray-500">Your cart is empty.</p>
    <% } else { %>
        <div class="space-y-4">
            <% cart.forEach(item => { %>
                <div class="flex items-center justify-between bg-gray-50 p-4 rounded-lg shadow-sm">
                    <div class="flex items-center space-x-4">
                        <img src="<%= item.image %>" alt="<%= item.name %>" class="w-20 h-20 object-cover rounded-md" />
                        <div>
                            <h3 class="text-xl font-semibold text-gray-800"><%= item.name %></h3>
                            <p class="text-gray-600">₹<%= item.price %></p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-4">
                        <form action="/buy/<%= item.id %>" method="POST">
                            <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded-md hover:bg-green-700 transition">
                                <i class="fas fa-shopping-bag mr-2"></i>Buy Now
                            </button>
                        </form>
                        <form action="/cart/remove/<%= item.id %>" method="POST">
                            <button type="submit" class="text-red-500 hover:text-red-700">
                                <i class="fas fa-trash-alt"></i> Remove
                            </button>
                        </form>
                    </div>
                </div>
            <% }); %>
        </div>

        <!-- Cart Total -->
        <div class="text-right mt-6">
            <p class="text-2xl font-bold text-gray-800">
                Total: ₹<%= cart.reduce((total, item) => total + item.price, 0) %>
            </p>
        </div>

        <!-- Actions -->
        <div class="flex justify-between items-center mt-8">
            <a href="/" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition duration-300">
                <i class="fas fa-arrow-left mr-2"></i>Continue Shopping
            </a>

            <form action="/checkout" method="POST" class="inline-form">
                <button type="submit" class="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition duration-300">
                    <i class="fas fa-shopping-cart mr-2"></i>Checkout All
                </button>
            </form>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
