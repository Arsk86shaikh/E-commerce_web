<%- include('partials/header') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="/css/styles.css">
<section class="hero">
 
    <div class="carousel">
        
            <div class="hero-content">
                <a href="/products" class="btn-primary">
                    <i class="fas fa-shopping-cart"></i> Shop Now
                </a>
            </div>
        </div>
    </div>
    
    
</section>
<section class="explore-categories">
    <h2>Explore Our Categories</h2>
    <div class="card-container">
        <div class="card">
            <img src="/images/brands .avif" alt="Electronics">
            <div class="card-content">
                <h3>Electronics</h3>
                <p>120 items</p>
                <a  class="btn-secondary">
                    <i class="fas fa-search"  ></i> Explore
                </a>
                
            </div>
        </div>
        <div class="card">
            <img src="/images/fasion.jpg" alt="Fashion">
            <div class="card-content">
                <h3>Fashion</h3>
                <p>200 items</p>
                <a href="/products?categories=Fashion" class="btn-secondary">
                    <i class="fas fa-search"></i> Explore
                </a>
                
            </div>
        </div>
        <div class="card">
            <img src="/images/living.jpg" alt="Home & Living">
            <div class="card-content">
                <h3>Home & Living</h3>
                <p>150 items</p>
                <a href="/products?categories=Living Items" class="btn-secondary">
                    <i class="fas fa-search"></i> Explore
                </a>
                
            </div>
        </div>
    </div>
</section>
<div class="categories">
    <% if (Array.isArray(categore) && categore.length > 0) { %>
        <% categore.forEach(category => { %>
            <div class="category">
                <h2 id="<%=categore.name%>"><%= category.name %></h2>
                <div class="products">
                    <% category.products.forEach(product => { %>
                        <div class="product-card" >
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image">
                            <div class="product-info">
                                <h3 class="brand"><%= product.name %></h3>
                                <p class="description"><%= product.description %></p>
                                <p class="price">Price: ₹<%= product.price %></p>
                                <div class="buttons">
                                    <form action="/buy/<%= product.id %>" method="POST" class="inline-form">
                                        <button type="submit" class="btn btn-buy">
                                            <i class="fas fa-shopping-bag"></i> Buy Now
                                        </button>
                                    </form>
                                    <form action="/cart/add/<%= product.id %>" method="POST" class="inline-form">
                                        <button type="submit" class="btn btn-cart">
                                            <i class="fas fa-cart-plus"></i> Add to Cart
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>   
                    <% }) %>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <p>No categories available.</p>
    <% } %>
</div>

<section class="special-offers">
    <h2>Special Offers</h2>
    <div class="offers-container">
        <div class="offer-card">
            <img src="/images/offer1.jpg" alt="Offer 1">
            <div class="offer-content">
                <h3>Up to 65% Off</h3>
                <p>On selected electronics</p>
                <a href="/products" class="btn-primary">
                    <i class="fas fa-shopping-cart"></i> Shop Now
                </a>
                
            </div>
        </div>
        <div class="offer-card">
            <img src="/images/offer2.webp" alt="Offer 2">
            <div class="offer-content">
                <h3>Up to 50% -80% Off</h3>
                <p>On all fashion items</p>
                <a href="/products" class="btn-primary">
                    <i class="fas fa-shopping-cart"></i> Shop Now
                </a>
                
            </div>
        </div>
    </div>
</section>
<section class="promo-banner">
    <div class="promo-content">
        <h2>Exclusive Deal of the Week!</h2>
        <p>Get an extra 10% off on all Fashion items.</p>
        <a href="/products?categories=fashion" class="btn-promo">
            <i class="fas fa-tags"></i> Grab the Deal
        </a>
    </div>
</section> 

<script>
    const carousel = document.querySelector('.carousel');
let isDown = false;
let startX;
let scrollLeft;

carousel.addEventListener('mousedown', (e) => {
    isDown = true;
    carousel.classList.add('active');
    startX = e.pageX - carousel.offsetLeft;
    scrollLeft = carousel.scrollLeft;
});

carousel.addEventListener('mouseleave', () => {
    isDown = false;
    carousel.classList.remove('active');
});

carousel.addEventListener('mouseup', () => {
    isDown = false;
    carousel.classList.remove('active');
});

carousel.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - carousel.offsetLeft;
    const walk = (x - startX) * 2; // The higher the multiplier, the faster the scroll
    carousel.scrollLeft = scrollLeft - walk;
});

carousel.addEventListener('touchstart', (e) => {
    isDown = true;
    startX = e.touches[0].pageX - carousel.offsetLeft;
    scrollLeft = carousel.scrollLeft;
});

carousel.addEventListener('touchmove', (e) => {
    if (!isDown) return;
    const x = e.touches[0].pageX - carousel.offsetLeft;
    const walk = (x - startX) * 2;
    carousel.scrollLeft = scrollLeft - walk;
});

carousel.addEventListener('touchend', () => {
    isDown = false;
});

</script>
<%- include('partials/footer') %>
