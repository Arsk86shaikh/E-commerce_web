<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="/css/styles.css">

<%- include('partials/header') %>

<h1>Our Products</h1>

<div class="categories">
    <% if (categories && categories.length > 0) { %>
        <% categories.forEach(category => { %>
            <section class="category">
                <h2><%= category.name %></h2>
                <div class="products">
                    <% if (category.products && category.products.length > 0) { %>
                        <% category.products.forEach(product => { %>
                            <div class="product-card">
                                <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image">
                                <div class="product-info">
                                    <h3><%= product.name %></h3>
                                    <p class="brand">Brand: <%= product.brand || "Unknown" %></p>
                                    <p class="description"><%= product.description || "No description available." %></p>
                                    <p class="price">Price: ₹ <%= product.price || "N/A" %></p>
                                    <p class="stock">Stock: <%= product.stock || "N/A" %></p>
                                    <p class="rating">⭐ Rating: <%= product.rating || "N/A" %></p>
                                    <div class="buttons">
                                        <form action="/buy/<%= product.id %>" method="POST" class="inline-form">
                                            <button type="submit" class="btn btn-buy">
                                                <i class="fas fa-shopping-bag"></i> Buy Now
                                            </button>
                                        </form>
                                        <form action="/cart/add/<%= product.id %>" method="POST" class="inline-form">
                                            <button type="submit" class="btn btn-cart">
                                                <i class="fas fa-cart-plus"></i> Add to Cart
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p>No products available in this category.</p>
                    <% } %>
                </div>
            </section>
        <% }); %>
    <% } else { %>
        <p>No categories available.</p>
    <% } %>
</div>

<%- include('partials/footer') %>
